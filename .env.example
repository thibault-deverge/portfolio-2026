# ============================================
# Variables d'environnement (Phase 2)
# Copier ce fichier en .env.local et renseigner les valeurs.
# Ne jamais committer .env.local (clés réelles).
# ============================================

# Contact — Resend (le destinataire = siteConfig.email, pas de variable)
# Clé : https://resend.com/api-keys
RESEND_API_KEY=

# IA concierge (palette ⌘K) — Anthropic
ANTHROPIC_API_KEY=

# Palette ⌘K — compteurs anti-abus (rate limit IP + budget global)
# Créé via Vercel Marketplace « Upstash for Redis », qui injecte les noms KV_*
# (guards.ts accepte aussi les noms UPSTASH_REDIS_REST_* d'un compte Upstash direct)
KV_REST_API_URL=
KV_REST_API_TOKEN=
